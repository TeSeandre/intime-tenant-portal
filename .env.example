VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_APP_ENV=development

# Stripe — frontend (safe to expose, used by Stripe.js)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe — server-side only (Vercel env vars, never prefix with VITE_)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase service role — server-side only (Vercel env vars, never prefix with VITE_)
# Used only in Vercel API routes (api/create-payment-intent.js, api/stripe-webhook.js)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
